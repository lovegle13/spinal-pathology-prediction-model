      "source": [
        "# -*- coding: utf-8 -*-\n",
        "\"\"\"\n",
        "СПЕЦИАЛИЗИРОВАННЫЙ АНАЛИЗ И ПРОГНОЗ ПО СОСТОЯНИЮ ПОЗВОНОЧНИКА\n",
        "Все данные по грыжам, протрузиям, стенозу, лечению за 2019-2026\n",
        "\"\"\"\n",
        "\n",
        "# Установка библиотек\n",
        "!pip install pandas numpy matplotlib seaborn scikit-learn xgboost\n",
        "\n",
        "import pandas as pd\n",
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.ensemble import RandomForestRegressor, GradientBoostingRegressor\n",
        "from sklearn.linear_model import LinearRegression\n",
        "from sklearn.metrics import r2_score, mean_absolute_error\n",
        "from sklearn.preprocessing import StandardScaler\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# ============================================================\n",
        "# 1. СБОР ВСЕХ ДАННЫХ ПО ПОЗВОНОЧНИКУ\n",
        "# ============================================================\n",
        "\n",
        "# Данные по шейному отделу (С4/С5, С5/С6)\n",
        "spine_data = pd.DataFrame({\n",
        "    'year': [2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026],\n",
        "\n",
        "    # Грыжи (размер в см)\n",
        "    'hernia_c4c5': [None, None, None, None, 0.4, 0.5, 0.55, 0.55],\n",
        "    'hernia_c5c6': [None, None, None, None, 0.3, 0.4, 0.45, 0.45],\n",
        "\n",
        "    # Стеноз (см)\n",
        "    'stenosis_c4c5': [None, None, None, None, 0.7, 0.8, 0.8, 0.8],\n",
        "    'stenosis_c5c6': [None, None, None, None, 0.7, 0.8, 0.8, 0.8],\n",
        "\n",
        "    # Протрузии (см)\n",
        "    'protrusion_c3c4': [None, None, None, None, None, None, 0.15, 0.15],\n",
        "    'protrusion_c6c7': [None, None, None, None, None, 0.2, 0.15, 0.15],\n",
        "\n",
        "    # Грудной отдел (новые в 2024)\n",
        "    'hernia_th7th8': [None, None, None, None, None, 0.4, 0.4, 0.4],\n",
        "    'protrusion_th8th12': [None, None, None, None, None, 'множественные', 'множественные', 'множественные'],\n",
        "\n",
        "    # Поясничный отдел\n",
        "    'hernia_l4l5': [None, None, None, None, None, 0.6, 0.6, 0.6],\n",
        "    'hernia_l5s1': [None, None, None, None, None, 0.5, 0.5, 0.5],\n",
        "    'retrolisthesis_l4': [None, None, None, None, None, 0.25, 0.25, 0.25],\n",
        "\n",
        "    # Гемангиолипомы\n",
        "    'hemangiomas_th': [None, None, None, None, None, 'Th6,Th12', 'Th6,Th12', 'Th6,Th12'],\n",
        "    'hemangiomas_l': [None, None, None, None, None, 'L2-L5', 'L2-L5', 'L2-L5'],\n",
        "})\n",
        "\n",
        "# Данные по лечению и процедурам\n",
        "treatments = pd.DataFrame({\n",
        "    'year': [2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026],\n",
        "\n",
        "    # Блокады\n",
        "    'blockades_count': [0, 0, 0, 0, 0, 0, 1, 3],  # 2025:1, 2026:3 (февраль)\n",
        "    'blockades_effect_days': [0, 0, 0, 0, 0, 0, 90, 3],  # 2025:90 дней эффекта, 2026:3 дня\n",
        "\n",
        "    # РЧА\n",
        "    'rfa_performed': [0, 0, 0, 0, 0, 0, 1, 0],  # Декабрь 2025\n",
        "    'rfa_effect_percent': [0, 0, 0, 0, 0, 0, 60, 0],  # Снижение боли на 60%\n",
        "\n",
        "    # Другое лечение\n",
        "    'prp_therapy': [0, 0, 0, 0, 0, 0, 1, 0],  # 2025: PRP (3 процедуры)\n",
        "    'sis_therapy': [0, 0, 0, 0, 0, 0, 1, 0],  # 2025: SIS (5 процедур)\n",
        "    'massage_courses': [0, 0, 0, 0, 0, 0, 1, 0],  # 2025: массаж\n",
        "\n",
        "    # Боль (по ВАШ, баллы)\n",
        "    'pain_level': [None, None, None, None, 7, 8, 5, 8],  # 2023:7, 2024:8, 2025:5 (после РЧА), 2026:8\n",
        "\n",
        "    # Миелопатия\n",
        "    'myelopathy': [0, 0, 0, 0, 0, 0, 0, 1],  # 2026: начальная миелопатия\n",
        "})\n",
        "\n",
        "# Клинические события\n",
        "clinical_events = pd.DataFrame({\n",
        "    'year': [2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026],\n",
        "    'event': [\n",
        "        'Сужение правой позвоночной артерии',\n",
        "        'Синдром позвоночной артерии',\n",
        "        'Постуральная неустойчивость',\n",
        "        'Нет данных',\n",
        "        'Впервые выявлены грыжи С4/С5, С5/С6. Стеноз 0,7 см',\n",
        "        'Тотальное поражение: грыжи в грудном и поясничном отделах. Стеноз 0,8 см',\n",
        "        'РЧА (декабрь) - снижение боли на 50-70%',\n",
        "        'НАЧАЛЬНАЯ МИЕЛОПАТИЯ! Фармакорезистентность к блокадам'\n",
        "    ]\n",
        "})\n",
        "\n",
        "print(\"=\"*80)\n",
        "print(\"ПОЛНЫЙ АНАЛИЗ СОСТОЯНИЯ ПОЗВОНОЧНИКА 2019-2026\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "print(\"\\n1. ДИНАМИКА ГРЫЖ:\")\n",
        "print(spine_data[['year', 'hernia_c4c5', 'hernia_c5c6', 'stenosis_c4c5']])\n",
        "print(\"\\n2. ЛЕЧЕНИЕ И ПРОЦЕДУРЫ:\")\n",
        "print(treatments[['year', 'blockades_count', 'blockades_effect_days', 'rfa_performed', 'pain_level', 'myelopathy']])\n",
        "print(\"\\n3. КЛИНИЧЕСКИЕ СОБЫТИЯ:\")\n",
        "print(clinical_events)\n",
        "\n",
        "# ============================================================\n",
        "# 2. ВИЗУАЛИЗАЦИЯ ДИНАМИКИ ПОЗВОНОЧНИКА\n",
        "# ============================================================\n",
        "\n",
        "fig, axes = plt.subplots(2, 2, figsize=(15, 10))\n",
        "fig.suptitle('ДИНАМИКА СОСТОЯНИЯ ПОЗВОНОЧНИКА 2019-2026', fontsize=16)\n",
        "\n",
        "# График 1: Размеры грыж\n",
        "years = spine_data['year'].values\n",
        "ax1 = axes[0, 0]\n",
        "ax1.plot(years, spine_data['hernia_c4c5'], 'o-', linewidth=2, markersize=8, label='Грыжа С4/С5')\n",
        "ax1.plot(years, spine_data['hernia_c5c6'], 's-', linewidth=2, markersize=8, label='Грыжа С5/С6')\n",
        "ax1.axhline(y=0.6, color='red', linestyle='--', alpha=0.7, label='Критический порог')\n",
        "ax1.set_xlabel('Год')\n",
        "ax1.set_ylabel('Размер (см)')\n",
        "ax1.set_title('Динамика размеров грыж')\n",
        "ax1.legend()\n",
        "ax1.grid(True, alpha=0.3)\n",
        "\n",
        "# График 2: Стеноз\n",
        "ax2 = axes[0, 1]\n",
        "ax2.plot(years, spine_data['stenosis_c4c5'], 'd-', linewidth=2, markersize=8, color='red', label='Стеноз С4/С5')\n",
        "ax2.axhline(y=0.7, color='orange', linestyle='--', alpha=0.7, label='Критический порог')\n",
        "ax2.axhline(y=0.8, color='red', linestyle='--', alpha=0.7, label='Критический (2024-2026)')\n",
        "ax2.set_xlabel('Год')\n",
        "ax2.set_ylabel('Стеноз (см)')\n",
        "ax2.set_title('Динамика стеноза позвоночного канала')\n",
        "ax2.legend()\n",
        "ax2.grid(True, alpha=0.3)\n",
        "\n",
        "# График 3: Эффективность лечения\n",
        "ax3 = axes[1, 0]\n",
        "ax3.bar(treatments['year'] - 0.2, treatments['blockades_effect_days'], width=0.4, label='Длительность эффекта блокад (дни)', color='blue', alpha=0.7)\n",
        "ax3.bar(treatments['year'] + 0.2, treatments['rfa_effect_percent'], width=0.4, label='Эффект РЧА (% снижения боли)', color='green', alpha=0.7)\n",
        "ax3.set_xlabel('Год')\n",
        "ax3.set_ylabel('Эффективность')\n",
        "ax3.set_title('Эффективность лечения')\n",
        "ax3.legend()\n",
        "ax3.grid(True, alpha=0.3)\n",
        "\n",
        "# График 4: Уровень боли и миелопатия\n",
        "ax4 = axes[1, 1]\n",
        "ax4.plot(years, treatments['pain_level'], 'o-', linewidth=2, markersize=8, color='purple', label='Уровень боли (ВАШ)')\n",
        "ax4.fill_between(years, 0, treatments['myelopathy'] * 10, alpha=0.3, color='red', label='Миелопатия')\n",
        "ax4.set_xlabel('Год')\n",
        "ax4.set_ylabel('Боль (баллы)')\n",
        "ax4.set_title('Уровень боли и развитие миелопатии')\n",
        "ax4.legend()\n",
        "ax4.grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig('spine_dynamics.png', dpi=150)\n",
        "plt.show()\n",
        "\n",
        "# ============================================================\n",
        "# 3. ПОДГОТОВКА ДАННЫХ ДЛЯ ML\n",
        "# ============================================================\n",
        "\n",
        "# Создание датасета для машинного обучения\n",
        "ml_data = pd.DataFrame({\n",
        "    'year': [2023, 2024, 2025, 2026],\n",
        "    'hernia_c4c5': [0.4, 0.5, 0.55, 0.55],\n",
        "    'hernia_c5c6': [0.3, 0.4, 0.45, 0.45],\n",
        "    'stenosis': [0.7, 0.8, 0.8, 0.8],\n",
        "    'pain_level': [7, 8, 5, 8],\n",
        "    'blockades_effect': [0, 0, 90, 3],\n",
        "    'rfa_done': [0, 0, 1, 0],\n",
        "    'myelopathy': [0, 0, 0, 1],\n",
        "    'weight': [92, 90, 89.5, 89.5],\n",
        "    'esr': [25, 18, 19, 26]  # воспаление\n",
        "})\n",
        "\n",
        "# Добавление лагов\n",
        "ml_data['hernia_c4c5_lag1'] = ml_data['hernia_c4c5'].shift(1)\n",
        "ml_data['hernia_c5c6_lag1'] = ml_data['hernia_c5c6'].shift(1)\n",
        "ml_data = ml_data.dropna().reset_index(drop=True)\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"ДАННЫЕ ДЛЯ МАШИННОГО ОБУЧЕНИЯ (2023-2026)\")\n",
        "print(\"=\"*80)\n",
        "print(ml_data)\n",
        "\n",
        "# ============================================================\n",
        "# 4. ПРОГНОЗ РАЗМЕРА ГРЫЖИ С4/С5\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"ПРОГНОЗ РАЗМЕРА ГРЫЖИ С4/С5 НА 2027-2028\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Признаки для прогноза\n",
        "X = ml_data[['year', 'pain_level', 'blockades_effect', 'rfa_done', 'myelopathy', 'weight', 'esr']]\n",
        "y = ml_data['hernia_c4c5']\n",
        "\n",
        "# Обучение модели\n",
        "model = GradientBoostingRegressor(n_estimators=50, random_state=42)\n",
        "model.fit(X, y)\n",
        "\n",
        "# Прогноз на 2027-2028\n",
        "future_years = [2027, 2028]\n",
        "future_data = pd.DataFrame({\n",
        "    'year': future_years,\n",
        "    'pain_level': [8, 8],  # предположительно боль сохранится\n",
        "    'blockades_effect': [3, 3],  # эффект блокад минимальный\n",
        "    'rfa_done': [0, 0],  # РЧА не делается ежегодно\n",
        "    'myelopathy': [1, 1],  # миелопатия сохранится\n",
        "    'weight': [89, 88.5],  # небольшое снижение веса\n",
        "    'esr': [26, 27]  # воспаление сохраняется\n",
        "})\n",
        "\n",
        "predictions = model.predict(future_data)\n",
        "\n",
        "print(\"\\nРЕЗУЛЬТАТЫ ПРОГНОЗА:\")\n",
        "print(\"-\" * 60)\n",
        "print(f\"{'Год':<10} {'Прогноз грыжи С4/С5 (см)':<25} {'Динамика':<20}\")\n",
        "print(\"-\" * 60)\n",
        "for i, year in enumerate(future_years):\n",
        "    prev = ml_data['hernia_c4c5'].iloc[-1] if i == 0 else predictions[i-1]\n",
        "    change = predictions[i] - prev\n",
        "    change_symbol = \"↗️\" if change > 0 else \"➡️\" if change == 0 else \"↘️\"\n",
        "    print(f\"{year:<10} {predictions[i]:<25.2f} {change_symbol} {change:+.2f} см\")\n",
        "print(\"-\" * 60)\n",
        "\n",
        "# Оценка риска\n",
        "print(\"\\nОЦЕНКА РИСКА НА 2027-2028:\")\n",
        "if predictions[-1] > 0.6:\n",
        "    print(\"⚠️ КРИТИЧЕСКИЙ РИСК: Грыжа превысит 0,6 см\")\n",
        "elif predictions[-1] > 0.55:\n",
        "    print(\"⚠️ ВЫСОКИЙ РИСК: Грыжа приближается к критическому размеру\")\n",
        "else:\n",
        "    print(\"✅ Стабильный прогноз\")\n",
        "\n",
        "# ============================================================\n",
        "# 5. ПРОГНОЗ ГРЫЖИ С5/С6\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"ПРОГНОЗ РАЗМЕРА ГРЫЖИ С5/С6 НА 2027-2028\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "y2 = ml_data['hernia_c5c6']\n",
        "model2 = GradientBoostingRegressor(n_estimators=50, random_state=42)\n",
        "model2.fit(X, y2)\n",
        "predictions2 = model2.predict(future_data)\n",
        "\n",
        "print(\"\\nРЕЗУЛЬТАТЫ ПРОГНОЗА:\")\n",
        "print(\"-\" * 60)\n",
        "print(f\"{'Год':<10} {'Прогноз грыжи С5/С6 (см)':<25} {'Динамика':<20}\")\n",
        "print(\"-\" * 60)\n",
        "for i, year in enumerate(future_years):\n",
        "    prev = ml_data['hernia_c5c6'].iloc[-1] if i == 0 else predictions2[i-1]\n",
        "    change = predictions2[i] - prev\n",
        "    change_symbol = \"↗️\" if change > 0 else \"➡️\" if change == 0 else \"↘️\"\n",
        "    print(f\"{year:<10} {predictions2[i]:<25.2f} {change_symbol} {change:+.2f} см\")\n",
        "print(\"-\" * 60)\n",
        "\n",
        "# ============================================================\n",
        "# 6. ПРОГНОЗ СТЕНОЗА\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"ПРОГНОЗ СТЕНОЗА ПОЗВОНОЧНОГО КАНАЛА НА 2027-2028\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "# Для стеноза используем простую модель (мало данных)\n",
        "stenosis_trend = np.polyfit([2023, 2024, 2025, 2026], [0.7, 0.8, 0.8, 0.8], 1)\n",
        "stenosis_pred = [2027 * stenosis_trend[0] + stenosis_trend[1],\n",
        "                 2028 * stenosis_trend[0] + stenosis_trend[1]]\n",
        "\n",
        "print(\"\\nРЕЗУЛЬТАТЫ ПРОГНОЗА:\")\n",
        "print(\"-\" * 60)\n",
        "print(f\"{'Год':<10} {'Прогноз стеноза (см)':<20} {'Риск':<20}\")\n",
        "print(\"-\" * 60)\n",
        "for i, year in enumerate(future_years):\n",
        "    risk = \"КРИТИЧЕСКИЙ\" if stenosis_pred[i] >= 0.8 else \"ВЫСОКИЙ\"\n",
        "    print(f\"{year:<10} {stenosis_pred[i]:<20.2f} {risk:<20}\")\n",
        "print(\"-\" * 60)\n",
        "\n",
        "# ============================================================\n",
        "# 7. АНАЛИЗ ЭФФЕКТИВНОСТИ ЛЕЧЕНИЯ\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"АНАЛИЗ ЭФФЕКТИВНОСТИ ЛЕЧЕНИЯ\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "treatment_analysis = pd.DataFrame({\n",
        "    'Метод': ['Блокады 2025', 'Блокады 2026', 'РЧА 2025'],\n",
        "    'Эффект': ['90% снижение боли', '2-3 дня (10-20%)', '50-70% снижение на 1-2 месяца'],\n",
        "    'Длительность': ['~3 месяца', '2-3 дня', '1-2 месяца'],\n",
        "    'Вывод': ['Высокоэффективно', 'Фармакорезистентность', 'Временный успех']\n",
        "})\n",
        "\n",
        "print(treatment_analysis.to_string(index=False))\n",
        "\n",
        "print(\"\\nКЛЮЧЕВОЙ ВЫВОД:\")\n",
        "print(\"• 2025: РЧА и блокады были эффективны (прорыв в лечении)\")\n",
        "print(\"• 2026: Развитие фармакорезистентности к блокадам\")\n",
        "print(\"• 2026: Появление миелопатии - требуется нейрохирург\")\n",
        "\n",
        "# ============================================================\n",
        "# 8. ИТОГОВАЯ ТАБЛИЦА ПРОГНОЗОВ\n",
        "# ============================================================\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"ИТОГОВАЯ ТАБЛИЦА ПРОГНОЗОВ ПО ПОЗВОНОЧНИКУ\")\n",
        "print(\"=\"*80)\n",
        "\n",
        "summary = pd.DataFrame({\n",
        "    'Показатель': ['Грыжа С4/С5 (см)', 'Грыжа С5/С6 (см)', 'Стеноз (см)', 'Миелопатия', 'Эффект блокад'],\n",
        "    '2026 (факт)': [0.55, 0.45, 0.8, 'Да', '2-3 дня'],\n",
        "    '2027 (прогноз)': [f\"{predictions[0]:.2f}\", f\"{predictions2[0]:.2f}\", f\"{stenosis_pred[0]:.2f}\", 'Да', 'Минимальный'],\n",
        "    '2028 (прогноз)': [f\"{predictions[1]:.2f}\", f\"{predictions2[1]:.2f}\", f\"{stenosis_pred[1]:.2f}\", 'Да', 'Минимальный'],\n",
        "    'Риск': ['Высокий', 'Высокий', 'Критический', 'Необратимо', 'Резистентность']\n",
        "})\n",
        "\n",
        "print(summary.to_string(index=False))\n",
        "\n",
        "print(\"\\n\" + \"=\"*80)\n",
        "print(\"РЕКОМЕНДАЦИИ НА 2027-2028:\")\n",
        "print(\"=\"*80)\n",
        "print(\"1. НЕЙРОХИРУРГИЧЕСКАЯ КОНСУЛЬТАЦИЯ - СРОЧНО (миелопатия!)\")\n",
        "print(\"2. Рассмотреть оперативное лечение (декомпрессия спинного мозга)\")\n",
        "print(\"3. Блокады неэффективны - искать альтернативные методы\")\n",
        "print(\"4. Контрольная МРТ каждые 6 месяцев\")\n",
        "print(\"5. ЛФК и реабилитация под контролем специалиста\")\n",
        "print(\"=\"*80)\n",
        "\n",
